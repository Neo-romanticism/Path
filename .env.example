# P.A.T.H 환경변수 설정 예시
# .env.example 파일을 .env로 복사한 후 실제 값을 입력하세요

# ===== 핵심 데이터베이스 및 서버 설정 =====
# PostgreSQL 연결 문자열 (로컬: postgresql://user:password@localhost:5432/path)
# Render: DATABASE_URL은 Render 환경에서 자동으로 제공됨
DATABASE_URL=postgresql://user:password@localhost:5432/path

# 실행 환경 (development, staging, production)
NODE_ENV=development

# 서버 포트
PORT=5000

# ===== 세션 및 보안 설정 =====
# 세션 암호화 키 (무작위 긴 문자열로 설정, 배포환경에서는 반드시 변경)
SESSION_SECRET=your_random_session_secret_min_32_chars_change_in_production

# CORS 허용 출처 (로컬: http://localhost:3000, 배포: https://yourdomain.com)
CORS_ORIGIN=http://localhost:3000

# 사이트 메인 URL (이메일 링크, 리다이렉트 등에 사용)
SITE_URL=http://localhost:5000

# ===== 구글 OAuth 로그인 설정 =====
# Google Cloud Console에서 발급
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# 백엔드 콜백 URL
GOOGLE_REDIRECT_URI=https://api.sdij.cloud/api/auth/google/callback
# 인증 성공/실패 후 이동할 경로
GOOGLE_AUTH_SUCCESS_REDIRECT=https://sdij.cloud/study-hub/
GOOGLE_AUTH_ERROR_REDIRECT=https://sdij.cloud/login/?error=google_auth

# ===== Apple OAuth 로그인 설정 =====
# Apple Developer Team ID (예: 1A2BC3D4E5)
APPLE_TEAM_ID=your_apple_team_id

# Apple Key ID (.p8 키 식별자)
APPLE_KEY_ID=your_apple_key_id

# Services ID (웹) 또는 Bundle ID (앱)
APPLE_CLIENT_ID=com.example.path.service

# Apple OAuth 콜백 URL
APPLE_REDIRECT_URI=https://api.sdij.cloud/api/auth/apple/callback

# Apple client secret JWT 생성용 개인키 파일 경로
APPLE_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# client secret JWT 만료일(일 단위, 최대 180)
APPLE_CLIENT_SECRET_EXPIRES_DAYS=180

# 생성된 JWT를 저장할 파일(선택)
APPLE_CLIENT_SECRET_OUT=.apple-client-secret.jwt

# 생성된 JWT를 APPLE_CLIENT_SECRET에 입력
APPLE_CLIENT_SECRET=replace_with_generated_jwt

# 인증 성공/실패 후 이동할 경로
APPLE_AUTH_SUCCESS_REDIRECT=https://sdij.cloud/study-hub/
APPLE_AUTH_ERROR_REDIRECT=https://sdij.cloud/login/?error=apple_auth

# ===== SSL/TLS 설정 (운영 환경에서만 필요) =====
# Render 같은 관리형 DB 사용 시 false로 설정 가능
DB_SSL_REJECT_UNAUTHORIZED=false

